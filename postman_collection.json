{
  "info": {
    "name": "Spring G17 API",
    "description": "Colección de endpoints para la API del blog Spring G17.\n\nBase URL: {{base_url}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "usuario_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "articulo_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Basic",
      "item": [
        {
          "name": "Hello",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/hello",
              "host": ["{{base_url}}"],
              "path": ["hello"]
            },
            "description": "Retorna \"Hello, World!\""
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "Hello, World!",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain"
                }
              ]
            }
          ]
        },
        {
          "name": "Bye",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/bye",
              "host": ["{{base_url}}"],
              "path": ["bye"]
            },
            "description": "Retorna \"Goodbye, World!\""
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "Goodbye, World!",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain"
                }
              ]
            }
          ]
        }
      ],
      "description": "Endpoints básicos de prueba"
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Crear Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has usuarioId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.usuarioId).to.not.be.null;",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('usuario_id', jsonData.usuarioId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/usuarios/save?dni=12345678",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "save"],
              "query": [
                {
                  "key": "dni",
                  "value": "12345678",
                  "description": "DNI del usuario (exactamente 8 digitos)"
                }
              ]
            },
            "description": "Crea un nuevo usuario.\n\nQuery parameters:\n- dni: obligatorio, exactamente 8 digitos"
          },
          "response": [
            {
              "name": "Created",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"usuarioId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"username\": \"jperez\",\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"dni\": \"12345678\",\n  \"estado\": true\n}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ]
            },
            {
              "name": "Validation Error",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"dni\": \"El DNI debe tener 8 digitos\",\n  \"username\": \"El username es obligatorio\"\n}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ]
            }
          ]
        },
        {
          "name": "Obtener Usuario por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has usuarioId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.usuarioId).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            },
            "description": "Obtiene un usuario por su UUID.\n\nPath parameter:\n- id (UUID): ID del usuario"
          },
          "response": [
            {
              "name": "Found",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"usuarioId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"username\": \"jperez\",\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"dni\": \"12345678\",\n  \"estado\": true\n}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ]
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "",
              "header": []
            }
          ]
        },
        {
          "name": "Agregar Rol a Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has roles array with the new role', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.roles).to.be.an('array');",
                  "    pm.expect(jsonData.roles).to.include.members([pm.request.url.query.get('role')]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
              "url": {
              "raw": "{{base_url}}/usuarios/role?role=ADMIN&usuarioId={{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "role"],
              "query": [
                {
                  "key": "role",
                  "value": "ADMIN",
                  "description": "Nombre del rol a asignar (ADMIN, INVITADO, OFFICER)"
                },
                {
                  "key": "usuarioId",
                  "value": "{{usuario_id}}",
                  "description": "UUID del usuario"
                }
              ]
            },
            "description": "Asigna un rol a un usuario existente.\n\nQuery parameters:\n- role (String): Nombre del rol (ADMIN, INVITADO, OFFICER)\n- usuarioId (UUID): ID del usuario"
          },
          "response": [
            {
              "name": "Role Assigned",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"usuarioId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"username\": \"jperez\",\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"dni\": \"12345678\",\n  \"estado\": true,\n  \"roles\": [\"ADMIN\"]\n}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ]
            },
            {
              "name": "Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "",
              "header": []
            }
          ]
        },
        {
          "name": "Cambiar Contraseña",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"nueva-contraseña-segura\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios/password/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "password", "{{usuario_id}}"]
            },
            "description": "Cambia la contraseña de un usuario.\n\nPath parameter:\n- id (UUID): ID del usuario\n\nBody:\n- password (String): Nueva contraseña"
          },
          "response": [
            {
              "name": "No Content",
              "status": "No Content",
              "code": 204,
              "body": "",
              "header": []
            }
          ]
        }
      ],
      "description": "Endpoints para gestion de usuarios"
    },
    {
      "name": "Articulos",
      "item": [
        {
          "name": "Crear Articulo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has idArticulo', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.idArticulo).to.not.be.null;",
                  "    pm.expect(jsonData.titulo).to.eql(JSON.parse(pm.request.body.raw).titulo);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('articulo_id', jsonData.idArticulo);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"titulo\": \"Mi primer articulo\",\n  \"contenido\": \"Este es el contenido del articulo.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/articulos/save",
              "host": ["{{base_url}}"],
              "path": ["articulos", "save"]
            },
            "description": "Crea un nuevo articulo asociado a un usuario existente.\n\nValidaciones:\n- idUsuario: obligatorio (UUID valido)\n- titulo: obligatorio\n- contenido: obligatorio"
          },
          "response": [
            {
              "name": "Created",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"idArticulo\": \"b2c3d4e5-f6a7-8901-bcde-f12345678901\",\n  \"titulo\": \"Mi primer articulo\",\n  \"contenido\": \"Este es el contenido del articulo.\",\n  \"fechaCreacion\": \"2026-07-06T12:00:00\",\n  \"fechaActualizacion\": \"2026-07-06T12:00:00\",\n  \"nombreUsuario\": \"jperez\"\n}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ]
            },
            {
              "name": "Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "",
              "header": []
            }
          ]
        },
        {
          "name": "Actualizar Articulo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 202', function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "pm.test('Response has updated idArticulo', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.idArticulo).to.not.be.null;",
                  "    pm.expect(jsonData.titulo).to.eql(JSON.parse(pm.request.body.raw).titulo);",
                  "});",
                  "",
                  "if (pm.response.code === 202) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('articulo_id', jsonData.idArticulo);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"titulo\": \"Mi articulo actualizado\",\n  \"contenido\": \"Este es el contenido actualizado del articulo.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/articulos/update/{{articulo_id}}",
              "host": ["{{base_url}}"],
              "path": ["articulos", "update", "{{articulo_id}}"]
            },
            "description": "Actualiza un articulo existente.\n\nPath parameter:\n- id (UUID): ID del articulo a actualizar\n\nValidaciones:\n- idUsuario: obligatorio (UUID valido)\n- titulo: obligatorio\n- contenido: obligatorio"
          },
          "response": [
            {
              "name": "Updated",
              "status": "Accepted",
              "code": 202,
              "body": "{\n  \"idArticulo\": \"b2c3d4e5-f6a7-8901-bcde-f12345678901\",\n  \"titulo\": \"Mi articulo actualizado\",\n  \"contenido\": \"Este es el contenido actualizado del articulo.\",\n  \"fechaCreacion\": \"2026-07-06T12:00:00\",\n  \"fechaActualizacion\": \"2026-07-07T12:00:00\",\n  \"nombreUsuario\": \"jperez\"\n}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ]
            },
            {
              "name": "Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "",
              "header": []
            }
          ]
        },
        {
          "name": "Eliminar Articulo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/articulos/delete/{{articulo_id}}?isDraft=true",
              "host": ["{{base_url}}"],
              "path": ["articulos", "delete", "{{articulo_id}}"],
              "query": [
                {
                  "key": "isDraft",
                  "value": "true",
                  "description": "Indica si el articulo se encuentra en estado borrador"
                }
              ]
            },
            "description": "Elimina un articulo existente.\n\nPath parameter:\n- idArticulo (UUID): ID del articulo a eliminar\n\nQuery parameters:\n- isDraft (boolean): Indica si el articulo es borrador para permitir eliminacion"
          },
          "response": [
            {
              "name": "No Content",
              "status": "No Content",
              "code": 204,
              "body": "",
              "header": []
            }
          ]
        }
      ],
      "description": "Endpoints para gestion de articulos"
    }
  ]
}
